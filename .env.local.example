# SMTP Configuration for contact form email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Recipient for all form submissions
CONTACT_TO=info@pssautomate.com

# Optional sender override (defaults to SMTP_USER)
SMTP_FROM=Manne Technologies <noreply@mannetechnologies.com>
